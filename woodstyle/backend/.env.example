APP_ENV=development
DEBUG=false

# Preferred local SQLite path, resolved from the backend directory.
WOODSTYLE_DATABASE_PATH=data/woodstyle.sqlite3

# Optional full SQLAlchemy URL. Use this instead of DATABASE_PATH for PostgreSQL.
# WOODSTYLE_DATABASE_URL=postgresql+psycopg://user:password@localhost/woodstyle
WOODSTYLE_SECRET_KEY=change-me-super-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14

CORS_ORIGINS=http://localhost:5173
ALLOWED_HOSTS=localhost,127.0.0.1

COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_HTTPONLY=true
CSRF_PROTECTION_ENABLED=true

RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=5/minute
RATE_LIMIT_REFRESH=20/minute
RATE_LIMIT_CONTACT=3/minute
RATE_LIMIT_CHECKOUT=10/minute
RATE_LIMIT_ADMIN=30/minute

MAX_UPLOAD_SIZE_MB=5
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
ALLOWED_IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.webp
MAX_IMAGE_PIXELS=40000000

SECURITY_HEADERS_ENABLED=true
LOG_LEVEL=INFO
