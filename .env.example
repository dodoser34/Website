APP_ENV=development
DEBUG=false

# Frontend
VITE_API_URL=http://localhost:8000/api/v1
VITE_FRONTEND_ONLY=false
VITE_AUTH_STORAGE_MODE=local
VITE_BASE_PATH=/
# VITE_GOOGLE_MAPS_EMBED_URL=

# Backend database
# Relative paths are resolved from woodstyle/backend.
WOODSTYLE_DATABASE_PATH=data/woodstyle.sqlite3
# WOODSTYLE_DATABASE_URL=sqlite:///data/woodstyle.sqlite3

# Backend security
WOODSTYLE_SECRET_KEY=change-me-super-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14

# Backend network
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOWED_HOSTS=localhost,127.0.0.1,testserver

# Cookies and CSRF
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_HTTPONLY=true
CSRF_PROTECTION_ENABLED=true

# Rate limits
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=5/minute
RATE_LIMIT_REFRESH=20/minute
RATE_LIMIT_CONTACT=3/minute
RATE_LIMIT_CHECKOUT=10/minute
RATE_LIMIT_ADMIN=30/minute

# Uploads
MAX_UPLOAD_SIZE_MB=5
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
ALLOWED_IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.webp
MAX_IMAGE_PIXELS=40000000

# Security headers and logging
SECURITY_HEADERS_ENABLED=true
LOG_LEVEL=INFO
